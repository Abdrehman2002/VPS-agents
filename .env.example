# ── Copy to .env and fill in ──────────────────────────────────────────────────

# LiveKit server (your self-hosted VPS server, or LiveKit Cloud)
LIVEKIT_URL=wss://your-livekit-domain-or-cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# LLM — OpenAI
OPENAI_API_KEY=
LLM_MODEL=gpt-4o
ANALYSIS_MODEL=gpt-4o-mini

# STT — Deepgram
DEEPGRAM_API_KEY=

# TTS — Uplift AI (Urdu). Get key + a real voice id from platform.upliftai.org
UPLIFTAI_API_KEY=
# Voice for Nadia (browse more at platform.upliftai.org)
UPLIFT_VOICE_ID=helpdesk-agent
UPLIFT_OUTPUT_FORMAT=MP3_22050_128

# Agent identity (dashboard dispatches by this name)
AGENT_NAME=nadia
HELPLINE=111-42-5000

# Itqan CRM — Nadia creates the complaint ticket here and reads back the TKT number
CRM_API_URL=          # e.g. https://your-crm-api/api/v1
CRM_TENANT_ID=        # your CRM tenant UUID
CRM_INGEST_SECRET=    # optional; must match LIVEKIT_INGEST_SECRET set on the CRM API

# Legacy/optional extra sinks
DASHBOARD_URL=
CRM_WEBHOOK_URL=
