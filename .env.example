# ── Copy to .env and fill in ──────────────────────────────────────────────────

# LiveKit server (your self-hosted VPS server, or LiveKit Cloud)
LIVEKIT_URL=wss://your-livekit-domain-or-cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# LLM — OpenAI
OPENAI_API_KEY=
LLM_MODEL=gpt-4o
ANALYSIS_MODEL=gpt-4o-mini

# STT — Deepgram
DEEPGRAM_API_KEY=

# TTS — Uplift AI (Urdu). Get key + a real voice id from platform.upliftai.org
UPLIFTAI_API_KEY=
# Voice for Nadia (browse more at platform.upliftai.org)
UPLIFT_VOICE_ID=helpdesk-agent
UPLIFT_OUTPUT_FORMAT=MP3_22050_128

# Agent identity (dashboard dispatches by this name)
AGENT_NAME=nadia
HELPLINE=111-42-5000

# Supabase (server-less backend) — Nadia files complaints via the create_complaint RPC
SUPABASE_URL=https://rdjiorobhuzchzwkkwyl.supabase.co
SUPABASE_SERVICE_KEY=    # service_role key: Supabase → Settings → API → service_role (secret)
CRM_TENANT_ID=43c45723-ed2d-4b27-a94f-76437c6988b7

# Legacy/optional extra sinks
DASHBOARD_URL=
CRM_WEBHOOK_URL=
